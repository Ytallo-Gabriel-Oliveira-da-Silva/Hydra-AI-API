generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  name           String
  passwordHash   String
  planId         String
  plan           Plan      @relation(fields: [planId], references: [id])
  currentPeriodEndsAt DateTime?
  blacklisted    Boolean   @default(false)
  violationCount Int       @default(0)
  countryCode    String?   // last detected ISO country
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  sessions       Session[]
  conversations  Conversation[]
  projects       Project[]
  investigations Investigation[]
  images         ImageAsset[]
  domains        Domain[]
  integrations   Integration[]
  quotas         QuotaUsage[]
  resetTokens    PasswordResetToken[]
  settings       UserSettings?
  familyMembers  FamilyMember[]
  payments       PaymentTransaction[]
  creditWallet   CreditWallet?
  creditLedgerEntries CreditLedgerEntry[]
  apiKeys        ApiKey[]
  apiRequestLogs ApiRequestLog[]
  cliLicenses    CliLicense[]
  cliDeviceActivations CliDeviceActivation[]
}

model Domain {
  id        String   @id @default(cuid())
  name      String
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, name])
}

model Integration {
  id        String   @id @default(cuid())
  name      String
  apiKey    String?
  domain    String?
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, name])
}

model Session {
  id         String   @id @default(cuid())
  token      String   @unique
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  createdAt  DateTime @default(now())
  expiresAt  DateTime
  ip         String?
  userAgent  String?
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  expiresAt DateTime
  used      Boolean  @default(false)
}

model Plan {
  id            String   @id @default(cuid())
  name          String
  slug          String   @unique
  monthlyPrice  Int?
  yearlyPrice   Int?
  badgeFrom     String
  badgeTo       String
  chatLimit     Int?
  imageLimit    Int?
  audioLimit    Int?
  videoLimit    Int?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  users         User[]
  payments      PaymentTransaction[]
}

model UserSettings {
  id         String   @id @default(cuid())
  userId     String   @unique
  user       User     @relation(fields: [userId], references: [id])
  payload    String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model FamilyMember {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  name       String
  email      String?
  createdAt  DateTime @default(now())

  @@unique([userId, name])
}

model PaymentTransaction {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  planId        String?
  plan          Plan?    @relation(fields: [planId], references: [id])
  productType   String   @default("plan")
  productRef    String?
  displayName   String?
  paymentMethod String
  amount        Int
  quantity      Int      @default(1)
  creditsGranted Int     @default(0)
  currency      String   @default("BRL")
  installments  Int?
  status        String
  paymentLink   String?
  pixCode       String?
  expiresAt     DateTime?
  metadata      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId, productType, createdAt])
}

model QuotaUsage {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  month      String   // YYYY-MM
  chatCount  Int      @default(0)
  imageCount Int      @default(0)
  audioCount Int      @default(0)
  videoCount Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([userId, month])
}

model Conversation {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  title     String
  createdAt DateTime  @default(now())
  messages  Message[]
}

model Message {
  id             String        @id @default(cuid())
  conversationId String
  conversation   Conversation  @relation(fields: [conversationId], references: [id])
  role           String
  content        String
  createdAt      DateTime      @default(now())
}

model Project {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  name      String
  status    String
  progress  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Investigation {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  title     String
  summary   String?
  createdAt DateTime @default(now())
}

model ImageAsset {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  title     String
  url       String
  createdAt DateTime @default(now())
}

model CreditWallet {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id])
  currency        String   @default("BRL")
  balanceCents    Int      @default(0)
  creditBalance   Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  ledgerEntries   CreditLedgerEntry[]
}

model CreditLedgerEntry {
  id              String   @id @default(cuid())
  walletId        String
  wallet          CreditWallet @relation(fields: [walletId], references: [id])
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  kind            String
  description     String?
  amountCents     Int      @default(0)
  credits         Int      @default(0)
  referenceType   String?
  referenceId     String?
  metadata        String?
  createdAt       DateTime @default(now())

  @@index([userId, createdAt])
}

model ApiKey {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  name          String
  prefix        String
  secretHash    String
  status        String   @default("active")
  scopes        String
  lastUsedAt    DateTime?
  expiresAt     DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  requestLogs   ApiRequestLog[]

  @@index([userId, status])
}

model ApiRequestLog {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  apiKeyId      String?
  apiKey        ApiKey?  @relation(fields: [apiKeyId], references: [id])
  resourceType  String
  endpoint      String
  statusCode    Int
  latencyMs     Int?
  creditCost    Int      @default(0)
  sourceIp      String?
  userAgent     String?
  metadata      String?
  createdAt     DateTime @default(now())

  @@index([userId, createdAt])
  @@index([apiKeyId, createdAt])
}

model CliLicense {
  id            String   @id @default(cuid())
  userId        String?
  user          User?    @relation(fields: [userId], references: [id])
  code          String   @unique
  status        String   @default("available")
  tier          String   @default("starter")
  seatLimit     Int      @default(1)
  deviceLimit   Int      @default(2)
  updatesUntil  DateTime?
  issuedAt      DateTime @default(now())
  activatedAt   DateTime?
  metadata      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  activations   CliDeviceActivation[]

  @@index([userId, status])
}

model CliDeviceActivation {
  id                String   @id @default(cuid())
  licenseId         String
  license           CliLicense @relation(fields: [licenseId], references: [id])
  userId            String
  user              User     @relation(fields: [userId], references: [id])
  deviceName        String
  deviceFingerprint String
  platform          String
  cliVersion        String
  lastSeenAt        DateTime?
  revokedAt         DateTime?
  createdAt         DateTime @default(now())

  @@unique([licenseId, deviceFingerprint])
  @@index([userId, createdAt])
}

model CliRelease {
  id           String   @id @default(cuid())
  version      String
  channel      String   @default("stable")
  platform     String
  arch         String
  downloadUrl  String
  checksum     String?
  notes        String?
  publishedAt  DateTime @default(now())
  createdAt    DateTime @default(now())

  @@unique([version, channel, platform, arch])
}
